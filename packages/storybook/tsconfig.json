{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "noEmit": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "storybook-static"]
}
