{
  "name": "storybook",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "npm run storybook",
    "build": "npm run build-storybook",
    "storybook": "node ./node_modules/storybook/bin/index.cjs dev -p 6006 --config-dir .storybook",
    "build-storybook": "node ./node_modules/storybook/bin/index.cjs build --config-dir .storybook --output-dir storybook-static",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "gantt-lib": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
